# ──────────────────────────────────────────────────────────────
# LLM Provider Configuration
# ──────────────────────────────────────────────────────────────

# Options: "ollama", "gemini", or "openai_compatible"
#   - ollama            → uses a locally-running Ollama server
#   - gemini            → uses Google Gemini API (requires GEMINI_API_KEY)
#   - openai_compatible → uses any OpenAI-compatible API (LM Studio, AnythingLLM, etc.)
LLM_PROVIDER=ollama

# Default model to use (must match the model name your provider expects)
# For Ollama:              "gemma3:4b", "qwen3:4b", "mistral:7b", etc.
# For Gemini:              "gemini-2.5-pro", "gemini-2.5-flash", etc.
# For OpenAI-compatible:   use the model name shown in LM Studio / AnythingLLM
DEFAULT_MODEL=gemma3:4b

# ──────────────────────────────────────────────────────────────
# Google Gemini (only needed if LLM_PROVIDER=gemini)
# ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ──────────────────────────────────────────────────────────────
# OpenAI-Compatible Provider (LM Studio / AnythingLLM)
# Only needed if LLM_PROVIDER=openai_compatible
# ──────────────────────────────────────────────────────────────

# LM Studio default:      http://localhost:1234/v1
# AnythingLLM default:    http://localhost:3001/api/v1
OPENAI_COMPATIBLE_BASE_URL=http://localhost:1234/v1

# API key (LM Studio doesn't need one; AnythingLLM requires one)
# For LM Studio:     leave as "not-needed"
# For AnythingLLM:   paste your API key from Settings → Developer
OPENAI_COMPATIBLE_API_KEY=not-needed

# ──────────────────────────────────────────────────────────────
# GitHub Token (optional — improves API rate limits)
# ──────────────────────────────────────────────────────────────
# GITHUB_TOKEN=your_github_token_here
